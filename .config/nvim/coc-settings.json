{
  "coc.preferences.rootPatterns": [
      ".git"
  ],
  "coc.preferences.bracketEnterImprove": true,
  "coc.preferences.enableFloatHighlight": true,
  /* "coc.preferences.formatOnSaveFiletypes": ["ts", "tsx", "js", "jsx", "css", "markdown"], */
  "clangd.path": "/home/danahparker/.config/coc/extensions/coc-clangd-data/install/10.0.0/clangd_10.0.0/bin/clangd",
  "languageserver": {
    "golang": {
      "command": "gopls",
      "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
      "filetypes": ["go"],
      "initializationOptions": {
        "usePlaceholders": true
      }
    }
  },
  "explorer.width": 30,
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "eslint.autoFixOnSave": false,
  "eslint.quiet": true,
  "tsserver.formatOnType": true,
  "yaml.customTags": [
    "!Ref",
		"!GetAtt",
		"!fn",
		"!And",
		"!If",
		"!Not",
		"!Equals",
		"!Or",
		"!FindInMap sequence",
		"!Base64",
		"!Cidr",
		"!Sub",
		"!GetAZs",
		"!ImportValue",
		"!Select",
		"!Split",
		"!Join sequence"
  ]
}
